	<s:String x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=C5F88D5021B65F4EA10F770D90CEBA14/Text/@EntryValue">using ScratchPad.lib;&#xD;
&#xD;
namespace ScratchPad;&#xD;
&#xD;
public static class $ClassName$&#xD;
{&#xD;
    public static void RunSingle($InputType$ arr)&#xD;
    {&#xD;
        Console.WriteLine(Environment.NewLine);&#xD;
        Console.WriteLine($"Running {nameof($ClassName$)}");&#xD;
&#xD;
        Execute(arr);&#xD;
&#xD;
        Console.WriteLine(arr);&#xD;
    }&#xD;
&#xD;
    public static void RunMultiple(List&lt;$InputType$&gt; items)&#xD;
    {&#xD;
        Console.WriteLine(Environment.NewLine);&#xD;
        Console.WriteLine($"Running {nameof($ClassName$)}");&#xD;
&#xD;
		foreach(var item in items)&#xD;
		{&#xD;
			Execute(item);&#xD;
		}&#xD;
    }&#xD;
&#xD;
    private static void Execute($InputType$ arr)&#xD;
    {&#xD;
       $END$&#xD;
    }&#xD;
