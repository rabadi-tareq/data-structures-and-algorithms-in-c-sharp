	<s:String x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=0531E52AD563EA48A6483A56EB9EE313/Text/@EntryValue">using ScratchPad.lib;&#xD;
&#xD;
namespace ScratchPad;&#xD;
&#xD;
public static class $ClassName$&#xD;
{&#xD;
    public static void RunSingle($FirstParamType$ arr, $SecondParamType$ $FactorParamName$)&#xD;
    {&#xD;
        Console.WriteLine(Environment.NewLine);&#xD;
        Console.WriteLine($"Running {nameof($ClassName$)}");&#xD;
&#xD;
        Execute(arr, $FactorParamName$);&#xD;
&#xD;
        Console.WriteLine(arr);&#xD;
    }&#xD;
&#xD;
    public static void RunMultiple(List&lt;($FirstParamType$ items, $SecondParamType$ $FactorParamName$)&gt; tuples)&#xD;
    {&#xD;
        Console.WriteLine(Environment.NewLine);&#xD;
        Console.WriteLine($"Running {nameof($ClassName$)}");&#xD;
&#xD;
		foreach(var tuple in tuples)&#xD;
		{&#xD;
			Execute(tuple.items, tuple.$FactorParamName$);&#xD;
		}&#xD;
    }&#xD;
&#xD;
    private static void Execute($FirstParamType$ arr, $SecondParamType$ $FactorParamName$)&#xD;
    {&#xD;
       $END$&#xD;
    }&#xD;
}</s:String>
